# claude-skills — config template.
# Copy to `.env` and fill in real values. `.env` is gitignored; this file is committed.
# Skills load it at runtime: `set -a; source ~/Developer/dodo-skills/.env; set +a`

# ── followup-mail ───────────────────────────────────────────────
FOLLOWUP_FROM_NAME=        # signature name, e.g. 홍길동
FOLLOWUP_TO=               # default recipient email
FOLLOWUP_SUBJECT_TAG=      # subject prefix shown as [TAG], e.g. Scenic

# ── voice-memo-to-notion ────────────────────────────────────────
NOTION_WS_SCENIC=          # primary Notion workspace id (UUID)
NOTION_WS_DODO=            # secondary/legacy workspace id (UUID)
NOTION_USER=               # Notion username slug used in page URLs
NOTION_1ON1_DS=            # 1on1 data_source id
NOTION_1ON1_DB=            # 1on1 database id
NOTION_1ON1_PARENT_PAGE=   # 1on1 parent page id
NOTION_MEETING_DB=         # 회의록 database id
NOTION_MEETING_DS=         # 회의록 data_source id
NOTION_DEFAULT_DB=         # default database id
NOTION_DEFAULT_DS=         # default data_source id
