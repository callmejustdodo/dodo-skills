# claude-skills — config template.
# Copy to `.env` and fill in real values. `.env` is gitignored; this file is committed.
# Skills load it at runtime. See each SKILL.md for the source command.

# ── followup-mail ───────────────────────────────────────────────
FOLLOWUP_FROM_NAME=        # signature name, e.g. 홍길동
FOLLOWUP_TO=               # default recipient email
FOLLOWUP_SUBJECT_TAG=      # subject prefix shown as [TAG], e.g. MyCompany

# ── voice-memo-to-notion ────────────────────────────────────────
NOTION_WS_PRIMARY=         # primary Notion workspace id (UUID)
NOTION_WS_LEGACY=          # secondary/legacy workspace id (UUID)
NOTION_USER=               # Notion username slug used in page URLs
NOTION_1ON1_DS=            # 1on1 data_source id
NOTION_1ON1_DB=            # 1on1 database id
NOTION_1ON1_PARENT_PAGE=   # 1on1 parent page id
NOTION_PRIMARY_MEETING_DB= # primary Meeting Notes database id (default for meetings)
NOTION_PRIMARY_MEETING_DS= # primary Meeting Notes data_source id (default target)
NOTION_MEETING_DB=         # 회의록 database id (legacy workspace)
NOTION_MEETING_DS=         # 회의록 data_source id (legacy workspace)
NOTION_DEFAULT_DB=         # default database id (legacy workspace)
NOTION_DEFAULT_DS=         # default data_source id (legacy workspace)
